<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <RootNamespace>Dil.Sample</RootNamespace>
    <IsPackable>false</IsPackable>
    <!-- Write generated files to obj/generated so you can inspect them -->
    <EmitCompilerGeneratedFiles>true</EmitCompilerGeneratedFiles>
    <!-- The deliberately-partial German file raises DIL001; keep it a warning, don't fail the demo. -->
    <WarningsNotAsErrors>$(WarningsNotAsErrors);DIL001</WarningsNotAsErrors>
  </PropertyGroup>

  <!-- In a real project these two lines come from the NuGet package automatically.
       Here we import them directly since the sample references the projects. -->
  <Import Project="..\..\src\Dil\build\Dil.props" />

  <ItemGroup>
    <ProjectReference Include="..\..\src\Dil\Dil.csproj" />
    <ProjectReference Include="..\..\src\Dil.Generator\Dil.Generator.csproj"
                      OutputItemType="Analyzer" ReferenceOutputAssembly="false" />
  </ItemGroup>

  <!-- Register the neutral file of each set; culture siblings (Strings.tr.json, …) are pulled in
       automatically. Culture comes from the filename. -->
  <ItemGroup>
    <DilResource Include="Resources/Strings.json" />
    <!-- A second, independent resource set -> generates a separate `Errors` class. -->
    <DilResource Include="Resources/Errors.json" />
  </ItemGroup>

  <Import Project="..\..\src\Dil\build\Dil.targets" />

</Project>
