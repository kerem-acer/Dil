<Project>

  <!-- Expose what the source generator needs to read from the consuming project. -->
  <ItemGroup>
    <CompilerVisibleProperty Include="RootNamespace" />
    <CompilerVisibleProperty Include="ProjectDir" />
    <CompilerVisibleProperty Include="DilAccessibility" />
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="DilResource" />
    <CompilerVisibleItemMetadata Include="AdditionalFiles" MetadataName="Accessibility" />
  </ItemGroup>

</Project>
